Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Delta]a1", "=", "0.5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Delta]a2", "=", "1.0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y0", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "2"}], 
     RowBox[{"Sin", "[", "x", "]"}]}], "+", "x", "+", "1.5"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"yp", "=", 
    RowBox[{
     RowBox[{"k", " ", "x"}], "+", "b"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sim", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"k", "\[Rule]", 
      RowBox[{"1", "/", "2"}]}], ",", 
     RowBox[{"b", "\[Rule]", 
      RowBox[{
       RowBox[{"-", "1"}], "/", "2"}]}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dy", "=", 
   RowBox[{"Cos", "[", 
    RowBox[{
     RowBox[{"yp", " ", "\[Pi]"}], "/.", "sim"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y1", "=", 
   RowBox[{"y0", "+", 
    RowBox[{"\[Delta]a1", " ", "dy"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y2", "=", 
   RowBox[{"y0", "+", 
    RowBox[{"\[Delta]a2", " ", "dy"}]}]}], ";"}], "\[IndentingNewLine]", 
