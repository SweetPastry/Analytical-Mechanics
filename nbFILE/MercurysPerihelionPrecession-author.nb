Cell[CellGroupData[{

Cell["", "DetailsSection"],

Cell[TextData[{
 "The general relativistic contribution can be approximated by the following \
model: ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]], "InlineMath"],
 " is the perturbation parameter given by"
}], "DetailNotes",
 CellChangeTimes->{
  3.35696210375764*^9, {3.412377009293676*^9, 3.41237705346704*^9}, {
   3.414766041151168*^9, 3.4147660993183203`*^9}, {3.4147781848590727`*^9, 
   3.414778187030934*^9}, {3.666050256973968*^9, 3.666050333148354*^9}},
 CellID->200555423],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"b", "=", 
    FractionBox[
     RowBox[{"3", " ", "G", " ", "M"}], 
     RowBox[{
      SuperscriptBox["c", "2"], " ", "a"}]]}], TraditionalForm]], 
  "InlineMath"],
 ","
}], "DetailNotes",
 CellChangeTimes->{
  3.35696210375764*^9, {3.4123718681237917`*^9, 3.412371902470311*^9}, {
   3.4147660815825186`*^9, 3.414766112879146*^9}},
 CellID->127687409],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]], "InlineMath"],
 " is the universal constant of gravitation, ",
 Cell[BoxData[
  FormBox["c", TraditionalForm]], "InlineMath"],
 " is the speed of light, and ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]], "InlineMath"],
 " is the mass of the Sun. Here ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "=", 
    RowBox[{"G", " ", 
     RowBox[{"M", "/", 
      SuperscriptBox["h", "2"]}]}]}], TraditionalForm]], "InlineMath"],
 ", where ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]], "InlineMath"],
 " is the angular momentum per unit mass ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "/", "m"}], TraditionalForm]], "InlineMath"],
 "."
}], "DetailNotes",
 CellChangeTimes->{
  3.35696210375764*^9, {3.412374381104842*^9, 3.4123745054523277`*^9}, {
   3.412377792419005*^9, 3.412377793187377*^9}, {3.4123787455803757`*^9, 
   3.4123787946329317`*^9}, {3.412378830096277*^9, 3.412378839945643*^9}, {
   3.412379066831327*^9, 3.412379071642577*^9}, {3.41476611873353*^9, 
   3.4147661415546417`*^9}, 3.4147662872218733`*^9},
 CellID->1755984462],

Cell[TextData[{
 "The perturbed solution, invoking the substitution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "=", 
    RowBox[{"1", "/", "u"}]}], TraditionalForm]], "InlineMath"],
 " is"
}], "DetailNotes",
 CellChangeTimes->{
  3.35696210375764*^9, 3.413325118106613*^9, {3.413325179676012*^9, 
   3.413325188907173*^9}, 3.666050423126532*^9},
 CellID->145732891],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["u", "1"], "(", "x", ")"}], "=", 
    RowBox[{
     SuperscriptBox["a", "3"], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        FractionBox["1", "6"], " ", 
        RowBox[{"cos", "(", 
         RowBox[{"2", " ", "x"}], ")"}], " ", 
        SuperscriptBox["e", "2"]}], "+", 
       FractionBox[
        SuperscriptBox["e", "2"], "2"], "+", "1"}], ")"}]}]}], 
   TraditionalForm]], "InlineMath"],
 ","
}], "DetailNotes",
 CellChangeTimes->{
  3.35696210375764*^9, {3.412372374567383*^9, 3.4123724162129087`*^9}, 
   3.412374895903412*^9, {3.412377182710567*^9, 3.4123772158027267`*^9}, {
   3.412377290423293*^9, 3.412377291227797*^9}, {3.4133251139980993`*^9, 
   3.413325124808247*^9}, 3.4147661647037287`*^9},
 CellID->706119710],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["e", TraditionalForm]], "InlineMath"],
 " is the eccentricity of the orbit;"
}], "DetailNotes",
 CellChangeTimes->{
  3.35696210375764*^9, {3.412374916173246*^9, 3.412374916558298*^9}, {
   3.412376657065241*^9, 3.412376664828738*^9}, {3.412377820291095*^9, 
   3.412377821243091*^9}, {3.412379949211257*^9, 3.412379959197543*^9}, {
   3.4147661714911337`*^9, 3.4147661803006525`*^9}, {3.4147782011870933`*^9, 
   3.414778203718327*^9}},
 CellID->1628725130],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"e", "=", 
    RowBox[{
     RowBox[{"A", "/", "a"}], "=", "0.205"}]}], TraditionalForm]], 
  "InlineMath"],
 "."
}], "DetailNotes",
 CellChangeTimes->{
  3.35696210375764*^9, {3.4123749240073547`*^9, 3.4123749362825623`*^9}, 
   3.412374971209835*^9, {3.412377384848915*^9, 3.412377405134162*^9}},
 CellID->9211601],

Cell["\<\
The relativistic analogue of the orbit trajectory in the two-body problem is\
\>", "DetailNotes",
 CellChangeTimes->{
  3.35696210375764*^9, {3.4123746138202467`*^9, 3.4123746487692833`*^9}, {
   3.412374800179675*^9, 3.412374821363675*^9}, {3.412381490384461*^9, 
   3.4123814915093718`*^9}, {3.412381652063561*^9, 3.412381660195774*^9}, 
   3.413325173214231*^9, {3.414766184674061*^9, 3.4147661850032425`*^9}},
 CellID->2110575760],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "=", 
    SuperscriptBox[
     RowBox[{"[", 
      RowBox[{"a", "-", 
       RowBox[{"A", " ", 
        RowBox[{"sin", "(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{"b", " ", 
             SuperscriptBox["a", "2"]}]}], ")"}], "\[Theta]"}], ")"}]}], "+", 
       "b"}], " ", "]"}], 
     RowBox[{"-", "1"}]]}], TraditionalForm]], "InlineMath"],
 "."
}], "DetailNotes",
 CellChangeTimes->{
  3.35696210375764*^9, {3.4123748324810343`*^9, 3.4123748739534616`*^9}, {
   3.414766187856147*^9, 3.4147661931073723`*^9}, {3.666050447517901*^9, 
   3.666050466218774*^9}},
 CellID->384361091]
}, Open  ]],

