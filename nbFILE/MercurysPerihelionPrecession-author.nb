Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "rad", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"rad", "[", 
        RowBox[{"\[Theta]_", ",", "M_", ",", "a_"}], "]"}], ":=", 
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"b", "=", 
           FractionBox[
            RowBox[{"3", " ", "G", " ", "M"}], 
            RowBox[{
             SuperscriptBox["c", "2"], " ", "a"}]]}], "}"}], ",", 
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"x", "=", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"1", "-", 
                RowBox[{
                 SuperscriptBox["a", "2"], " ", "b"}]}], ")"}], " ", 
              "\[Theta]"}]}], "}"}], ",", 
           FractionBox["1", 
            RowBox[{"1", "-", 
             RowBox[{"e", " ", 
              RowBox[{"Sin", "[", "x", "]"}]}], "+", 
             RowBox[{"b", " ", 
              SuperscriptBox["a", "2"], " ", 
              RowBox[{"(", 
               RowBox[{"1", "+", 
                FractionBox[
                 SuperscriptBox["e", "2"], "2"], "+", 
                RowBox[{
                 FractionBox["1", "6"], " ", 
                 SuperscriptBox["e", "2"], " ", 
                 RowBox[{"Cos", "[", 
                  RowBox[{"2", " ", "x"}], "]"}]}]}], ")"}]}]}]]}], "]"}]}], 
        "]"}]}], ";", 
      RowBox[{"ParametricPlot", "[", 
       RowBox[{
        RowBox[{"Evaluate", "[", 
         RowBox[{
          RowBox[{"rad", "[", 
           RowBox[{"\[Theta]", ",", 
            RowBox[{"M", " ", 
             SuperscriptBox["10", "36"]}], ",", 
            FractionBox["a", 
             SuperscriptBox["10", "11"]]}], "]"}], 
          RowBox[{"{", " ", 
           RowBox[{
            RowBox[{"Cos", "[", "\[Theta]", "]"}], ",", " ", 
            RowBox[{"Sin", "[", "\[Theta]", "]"}]}], "}"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Theta]", ",", "0", ",", "t"}], "}"}], ",", 
        RowBox[{"PlotRange", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "1.2"}], ",", "1.2"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "1.2"}], ",", "1.2"}], "}"}]}], "}"}]}], ",", 
        RowBox[{"Frame", "\[Rule]", "True"}], ",", 
