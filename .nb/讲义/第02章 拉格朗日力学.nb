           FontColor->RGBColor[1, 0, 1]]}]],
        FontColor->RGBColor[0., 0.5019607843137255, 0.]]}]}], "=", 
     RowBox[{
      OverscriptBox[
       UnderscriptBox["\[Sum]", 
        RowBox[{"\[Beta]", "=", "1"}]], "d"], 
      RowBox[{
       SubscriptBox[
        StyleBox["P",
