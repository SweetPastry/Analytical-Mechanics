     RowBox[{
      OverscriptBox[
       UnderscriptBox["\[Sum]", 
        RowBox[{"\[Beta]", "=", "1"}]], "d"], 
      RowBox[{
       StyleBox[
        FractionBox[
         RowBox[{"\[PartialD]", 
          RowBox[{"L", "(", 
           RowBox[{"s", ",", 
            OverscriptBox["s", 
             StyleBox[".",
              FontWeight->"Bold"]], ",", "t"}], ")"}]}], 
