Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Theta]1", "=", 
   RowBox[{"30", "Degree"}]}], ";", "    ", 
  RowBox[{"\[Phi]1", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Theta]2", "=", 
    RowBox[{"90", "Degree"}]}], ";", "  ", 
   RowBox[{"\[Phi]2", "=", 
    RowBox[{"\[Pi]", "/", "2"}]}], ";"}], "  ", "\[IndentingNewLine]", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"v1", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"Sin", "[", "\[Theta]1", "]"}], 
      RowBox[{"Cos", "[", "\[Phi]1", "]"}]}], ",", 
     RowBox[{
      RowBox[{"Sin", "[", "\[Theta]1", "]"}], 
      RowBox[{"Sin", "[", "\[Phi]1", "]"}]}], ",", 
     RowBox[{"Cos", "[", "\[Theta]1", "]"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"v2", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"Sin", "[", "\[Theta]2", "]"}], 
      RowBox[{"Cos", "[", "\[Phi]2", "]"}]}], ",", 
     RowBox[{
      RowBox[{"Sin", "[", "\[Theta]2", "]"}], 
      RowBox[{"Sin", "[", "\[Phi]2", "]"}]}], ",", 
     RowBox[{"Cos", "[", "\[Theta]2", "]"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"v", "=", 
   RowBox[{"v1", "\[Cross]", "v2"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eq", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"v", ".", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Sin", "[", "\[Theta]", "]"}], 
        RowBox[{"Cos", "[", "\[Phi]", "]"}]}], ",", 
       RowBox[{
        RowBox[{"Sin", "[", "\[Theta]", "]"}], 
        RowBox[{"Sin", "[", "\[Phi]", "]"}]}], ",", 
       RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eq", "=", 
   RowBox[{"Expand", "[", 
    RowBox[{"%", "/", 
     RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol", "=", 
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{"eq", "\[Equal]", "0"}], ",", 
     RowBox[{"Tan", "[", "\[Theta]", "]"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"t", "=", 
   RowBox[{
    RowBox[{"Tan", "[", "\[Theta]", "]"}], "/.", 
    RowBox[{"sol", "[", 
     RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"t1", "=", 
   RowBox[{"Numerator", "[", "t", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"t2", "=", 
   RowBox[{"Denominator", "[", "t", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"c", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"t2", "/", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"t1", "  ", "t1"}], "+", 
        RowBox[{"t2", " ", "t2"}]}], ")"}], 
      RowBox[{"1", "/", "2"}]]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"s", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"t1", "/", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"t1", "  ", "t1"}], "+", 
        RowBox[{"t2", " ", "t2"}]}], ")"}], 
      RowBox[{"1", "/", "2"}]]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FullSimplify", "[", 
   RowBox[{"1", "/", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"s", " ", "s"}], " ", "+", " ", 
      RowBox[{"c", " ", "c"}]}], ")"}]}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{
  3.8131432293753014`*^9, 3.8131432901836123`*^9, {3.8131433461796684`*^9, 
