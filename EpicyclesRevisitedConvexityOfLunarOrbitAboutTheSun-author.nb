Cell[CellGroupData[{

Cell["", "DetailsSection"],

Cell["\<\
The three-body Sun-Earth-Moon problem can be described by the Lagrangian\
\>", "DetailNotes",
 CellChangeTimes->{{3.544107586377842*^9, 3.5441076927047043`*^9}, {
  3.544107847021144*^9, 3.544107847372932*^9}},
 CellID->1491454447],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{"L", "=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "2"], 
     SubscriptBox["m", "A"], " ", 
     SubsuperscriptBox[
      OverscriptBox["R", "."], "A", "2"]}], "+", 
    RowBox[{
     FractionBox["1", "2"], 
     SubscriptBox["m", "B"], " ", 
     SubsuperscriptBox[
      OverscriptBox["R", "."], "B", "2"]}], "+", 
    FractionBox[
     RowBox[{"G", " ", "M", " ", 
      SubscriptBox["m", "A"]}], 
     SubscriptBox["R", "A"]], "+", 
    FractionBox[
     RowBox[{"G", " ", "M", " ", 
      SubscriptBox["m", "B"]}], 
     SubscriptBox["R", "B"]], "+", 
    FractionBox[
     RowBox[{"G", " ", 
      SubscriptBox["m", "A"], 
      SubscriptBox["m", "B"]}], 
     SubscriptBox["R", 
      RowBox[{"A", ",", "B"}]]]}]}], 
  TraditionalForm]], "InlineMath"]], "DetailNotes",
 CellChangeTimes->{{3.544107697043874*^9, 3.544107741986587*^9}, {
  3.5441079308271627`*^9, 3.544107984021792*^9}, {3.544108018525404*^9, 
  3.544108153341899*^9}, {3.544108245336008*^9, 3.544108312534161*^9}, {
  3.5441084421801863`*^9, 3.54410847539463*^9}, {3.544541766281829*^9, 
  3.544541812663319*^9}},
 CellID->1445762945],

Cell[TextData[{
 "where the Sun is taken as the origin of the coordinate system and is thus \
considered stationary. Here ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]], "InlineMath"],
 " represents the gravitational constant, ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]], "InlineMath"],
 " the solar mass, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "A"], TraditionalForm]], "InlineMath"],
 " the lunar (or other moon) mass, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "B"], Cell["", "InlineMath"]}], TraditionalForm]], 
  "InlineMath"],
 "the Earth (or other planetary mass), and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["R", "A"], TraditionalForm]], "InlineMath"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["R", "B"], TraditionalForm]], "InlineMath"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["R", 
    RowBox[{"A", ",", "B"}]], TraditionalForm]], "InlineMath"],
 " the three interbody distances. Because of the great disparity in masses \
and in distances, an accurate simplification of the problem is possible. For \
the Sun-Earth-Moon system, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"M", "/", 
     SubscriptBox["m", "B"]}], "\[TildeTilde]", 
    RowBox[{"330", " ", "000"}]}], TraditionalForm]], "InlineMath"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["m", "B"], "/", 
     SubscriptBox["m", "A"]}], "\[TildeTilde]", "81.3"}], TraditionalForm]], 
  "InlineMath"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["R", "A"], ",", 
    RowBox[{
     SubscriptBox["R", "B"], "\[TildeTilde]", 
     RowBox[{"400", " ", 
      SubscriptBox["R", 
       RowBox[{"A", ",", "B"}]]}]}]}], TraditionalForm]], "InlineMath"],
 ". The Lagrangian is well approximated by "
}], "DetailNotes",
 CellChangeTimes->{{3.544108594352319*^9, 3.544108675943429*^9}, {
  3.5441087110287247`*^9, 3.544108818195812*^9}, {3.5441088633200207`*^9, 
  3.544109005185624*^9}, {3.544109056261991*^9, 3.544109058773924*^9}, {
  3.544109089475065*^9, 3.544109195955595*^9}, {3.544109250680457*^9, 
  3.544109338784007*^9}, {3.5441093804869556`*^9, 3.544109434623397*^9}, {
  3.544109528942045*^9, 3.544109890445073*^9}, {3.544109939077009*^9, 
  3.5441099412391853`*^9}, {3.5441099806589537`*^9, 3.544110062109779*^9}, {
  3.5441237620392523`*^9, 3.54412376355303*^9}, {3.544541702355816*^9, 
  3.544541746313653*^9}, {3.544541847599628*^9, 3.544541902070685*^9}, {
  3.544541964120784*^9, 3.544541964411618*^9}, {3.544543020783093*^9, 
  3.544543033661269*^9}},
 CellID->160350810],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "\[TildeTilde]", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["m", "A"], "+", 
        SubscriptBox["m", "B"]}], ")"}], " ", 
      SuperscriptBox["R", "2"], 
      SuperscriptBox["\[CapitalOmega]", "2"]}], "+", 
     RowBox[{
      FractionBox["1", "2"], 
      FractionBox[
       RowBox[{
        SubscriptBox["m", "A"], 
        SubscriptBox["m", "B"]}], 
       RowBox[{
        SubscriptBox["m", "A"], "+", 
        SubscriptBox["m", "B"]}]], " ", 
      SuperscriptBox["r", "2"], 
      SuperscriptBox["\[Omega]", "2"]}], "+", 
     FractionBox[
      RowBox[{"G", " ", 
       RowBox[{"M", "(", 
        RowBox[{
         SubscriptBox["m", "A"], "+", 
         SubscriptBox["m", "B"]}], ")"}]}], "R"], "+", 
     RowBox[{
      FractionBox[
       RowBox[{"G", " ", 
        SubscriptBox["m", "A"], " ", 
        SubscriptBox["m", "B"]}], "r"], "[", 
      RowBox[{"1", "+", 
       RowBox[{
        StyleBox["O",
         FontSlant->"Plain"], "(", 
        RowBox[{
         SuperscriptBox["r", "2"], "/", 
         SuperscriptBox["R", "2"]}], ")"}]}]}]}]}], TraditionalForm]], 
  "InlineMath"],
 "]"
}], "DetailNotes",
 CellChangeTimes->{{3.544110099905652*^9, 3.544110133645259*^9}, {
  3.5441102067567472`*^9, 3.544110352977934*^9}, {3.544110393075755*^9, 
  3.544110616507471*^9}, {3.544110711644965*^9, 3.544110719588717*^9}, {
  3.544465075024055*^9, 3.544465153480303*^9}, {3.544541983632844*^9, 
  3.5445419952677593`*^9}, {3.544542027355895*^9, 3.544542031058962*^9}, {
  3.5445421375184107`*^9, 3.544542142823688*^9}},
 CellID->2071570332],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]], "InlineMath"],
 " is the distance from the Sun to the Earth-Moon barycenter (",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "\[TildeTilde]", 
    SubscriptBox["R", "A"], "\[TildeTilde]", 
    SubscriptBox["R", "B"]}], TraditionalForm]], "InlineMath"],
 ") and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "=", 
    RowBox[{
     SubscriptBox["R", 
      RowBox[{"A", ",", "B"}]], "=", 
     RowBox[{"a", "+", "b"}]}]}], TraditionalForm]], "InlineMath"],
 ". The simplest case is when both orbital motions are circular, with angular \
velocities ",
 Cell[BoxData[
  FormBox["\[CapitalOmega]", TraditionalForm]], "InlineMath"],
 " (\"annual\") and ",
 Cell[BoxData[
  FormBox["\[Omega]", TraditionalForm]], "InlineMath"],
 " (\"monthly\"). To a fair approximation, there are 13 lunar months per \
solar year: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Omega]", "/", "\[CapitalOmega]"}], "\[TildeTilde]", "13"}], 
   TraditionalForm]], "InlineMath"],
 "."
}], "DetailNotes",
 CellChangeTimes->{{3.544110927645385*^9, 3.5441110096960297`*^9}, {
   3.544111796025601*^9, 3.544111874980754*^9}, {3.544111908047695*^9, 
   3.544111953079789*^9}, {3.5441120123885508`*^9, 3.544112062883758*^9}, {
   3.54411211126849*^9, 3.5441122411094923`*^9}, {3.544112299336526*^9, 
   3.544112382044223*^9}, {3.5441124434354963`*^9, 3.544112529659617*^9}, 
   3.5441126612257137`*^9, {3.544112772471552*^9, 3.544112820535611*^9}, {
   3.544112857028013*^9, 3.5441128682197037`*^9}, 3.54411290141492*^9, 
   3.5441129473255444`*^9, {3.5441129842676*^9, 3.544113195517231*^9}, {
   3.544113366783065*^9, 3.5441134140878057`*^9}, {3.544113486570942*^9, 
   3.5441135476128683`*^9}, {3.544123710876025*^9, 3.54412371226501*^9}, 
   3.544187667218019*^9, {3.544374348160721*^9, 3.544374348169284*^9}, {
   3.544542032864785*^9, 3.544542059257992*^9}, {3.544542148058114*^9, 
   3.544542176102943*^9}, {3.544543233939412*^9, 3.544543241211499*^9}},
 CellID->1877684760],

Cell["\<\
The thumbnail graphic for this Demonstration shows epichoroidal orbits for a \
hypothetical twin planet around some other star, in which a planet and its \
moon are of equal mass.\
\>", "DetailNotes",
 CellChangeTimes->{{3.544374348624517*^9, 3.544374537638686*^9}, {
   3.5443755984899597`*^9, 3.544375634326932*^9}, {3.544375932084765*^9, 
   3.5443759325207977`*^9}, 3.544543275817294*^9},
 CellID->545765304],

Cell["\<\
Snapshot 1: a qualitative representation for a planet with a very massive \
moon; for example Pluto's moon Charon has approximately 11.6% of the mass of \
the planet\
\>", "DetailNotes",
 CellChangeTimes->{{3.5443745393805943`*^9, 3.544374550214698*^9}, {
   3.544374583389083*^9, 3.544374871457337*^9}, 3.5443759598348923`*^9},
 CellID->2004552976],

Cell[TextData[{
 "Snapshot 2: the Sun-Earth-Moon system drawn to scale, with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "\[TildeTilde]", " ", 
    RowBox[{"400", " ", "r"}]}], TraditionalForm]], "InlineMath"],
 " (average Sun-Earth distance is about 400 times average Earth-Moon \
distance) and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[TildeTilde]", "13"}], TraditionalForm]], "InlineMath"],
 " (lunar months per year); with higher magnification, it can be seen that \
the Moon's orbit around the Sun is a distorted 13-sided polygon that is a \
convex figure"
}], "DetailNotes",
 CellChangeTimes->{
  3.54437457646375*^9, {3.5443749105379066`*^9, 3.544375283464904*^9}, {
   3.544375694256815*^9, 3.544375723589514*^9}, {3.544543306651245*^9, 
   3.544543307089381*^9}, {3.545427154037784*^9, 3.545427259287733*^9}, {
   3.545427302993701*^9, 3.545427312100822*^9}},
 CellID->1457800816],

Cell[TextData[{
 "Snapshot 3: a toy model of the Sun-Earth-Moon system, with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "\[TildeTilde]", "20"}], TraditionalForm]], "InlineMath"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "=", "4"}], TraditionalForm]], "InlineMath"],
 ", in which the requisite inequality for convexity is fulfilled and much \
easier to verify"
}], "DetailNotes",
 CellChangeTimes->{
  3.5443745805016127`*^9, {3.544375292504231*^9, 3.544375452450367*^9}, {
   3.544375485723068*^9, 3.544375520157586*^9}, {3.544375555038156*^9, 
   3.544375567997987*^9}, {3.5443757970886383`*^9, 3.544375799184379*^9}, 
   3.54437596740956*^9, {3.544465750262575*^9, 3.5444657502628098`*^9}, {
   3.544465793672902*^9, 3.544465793673109*^9}, {3.545484020896097*^9, 
   3.5454840215882463`*^9}},
 CellID->617385889],

