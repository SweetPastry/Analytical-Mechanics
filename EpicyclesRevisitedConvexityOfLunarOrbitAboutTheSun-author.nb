Cell[CellGroupData[{

Cell["", "ManipulateCaptionSection"],

Cell["\<\
Kepler's laws of planetary motion in the 17th century superseded the \
Ptolemaic system of epicycles to account for the detailed motions of the \
planets. Generalizations of epicycloids, called epitroichoids, still do \
occur, however, in the description of relative planet-moon motions as their \
barycenters (centers of gravity) follow Keplerian orbits around the Sun.\
\>", "ManipulateCaption",
 CellChangeTimes->{{3.5441136299137363`*^9, 3.544113708958335*^9}, {
   3.544113745715774*^9, 3.54411379011644*^9}, {3.544113897262569*^9, 
   3.544113908519519*^9}, {3.5441139652756147`*^9, 3.544113967520008*^9}, {
   3.544114053904351*^9, 3.544114191198769*^9}, {3.544114227597472*^9, 
   3.5441143428810883`*^9}, {3.544114391867889*^9, 3.5441143924598217`*^9}, {
   3.544114598418475*^9, 3.54411462460247*^9}, {3.544114677946836*^9, 
   3.5441146808526793`*^9}, {3.544123584380638*^9, 3.5441235898865213`*^9}, {
   3.5441236328171673`*^9, 3.5441236389269743`*^9}, 3.5444643795346255`*^9, 
   3.544464426160288*^9, 3.5445406010025*^9},
 CellID->1899771866],

Cell[TextData[{
 "We consider a simplified idealized case, which is justified in the Details: \
a moon (red point ",
 Cell[BoxData[
  FormBox[
   StyleBox["A",
    FontSlant->"Plain"], TraditionalForm]], "InlineMath"],
 ") with mass ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "A"], TraditionalForm]], "InlineMath"],
 " is in a circular orbit about its planet (blue point ",
 Cell[BoxData[
  FormBox[
   StyleBox["B",
    FontSlant->"Plain"], TraditionalForm]], "InlineMath"],
 ") with mass ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "B"], TraditionalForm]], "InlineMath"],
 ", with the moon-planet distance equal to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "=", 
    RowBox[{"a", "+", "b"}]}], TraditionalForm]], "InlineMath"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "=", 
    RowBox[{
     FractionBox[
      SubscriptBox["m", "B"], 
      RowBox[{
       SubscriptBox["m", "A"], "+", 
       SubscriptBox["m", "B"]}]], "r"}]}], TraditionalForm]], "InlineMath"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"b", "=", 
    RowBox[{
     FractionBox[
      SubscriptBox["m", "A"], 
      RowBox[{
       SubscriptBox["m", "A"], "+", 
       SubscriptBox["m", "B"]}]], "r"}]}], TraditionalForm]], "InlineMath"],
 " are the respective distances of the moon and planet from their barycenter. \
The barycenter of this pair is in a circular orbit of radius ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]], "InlineMath"],
 " about the Sun. With the Sun at the origin, the parametric equations for ",
 Cell[BoxData[
  FormBox[
   StyleBox["A",
    FontSlant->"Plain"], TraditionalForm]], "InlineMath"],
 " and ",
 Cell[BoxData[
  FormBox[
   StyleBox["B",
    FontSlant->"Plain"], TraditionalForm]], "InlineMath"],
 " can be written"
}], "ManipulateCaption",
 CellChangeTimes->{{3.544114980729862*^9, 3.544115013529612*^9}, {
   3.54412305787002*^9, 3.544123226311203*^9}, {3.5441232698319063`*^9, 
   3.544123270875518*^9}, {3.544123348258202*^9, 3.544123373449902*^9}, {
   3.54412341038148*^9, 3.5441234720041018`*^9}, {3.544123622659403*^9, 
   3.5441236262401648`*^9}, {3.544137396598805*^9, 3.5441374048850594`*^9}, {
   3.544138004282653*^9, 3.544138070965762*^9}, {3.5441383460489283`*^9, 
   3.5441384159860153`*^9}, {3.544138473264208*^9, 3.544138556436364*^9}, {
   3.544138597889597*^9, 3.544138599148176*^9}, {3.544138631023561*^9, 
   3.5441386339810467`*^9}, {3.544187330171711*^9, 3.544187372121204*^9}, {
   3.544187407763957*^9, 3.544187408698011*^9}, {3.544540673084791*^9, 
   3.544540693782629*^9}, {3.544540799152666*^9, 3.544540873929901*^9}, {
   3.544542224120768*^9, 3.544542225103031*^9}, {3.5445430980972*^9, 
   3.544543180202785*^9}, 3.545483905455419*^9},
 CellID->129930574],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "A"], "=", 
    RowBox[{
     RowBox[{"R", " ", "cos", " ", "\[Phi]"}], "-", 
     RowBox[{"a", " ", 
      RowBox[{"cos", "(", 
       RowBox[{"m", " ", "\[Phi]"}], ")"}], " "}]}]}], TraditionalForm]], 
  "InlineMath"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", "A"], "=", 
    RowBox[{
     RowBox[{"R", " ", "sin", " ", "\[Phi]"}], "-", 
     RowBox[{"a", " ", 
      RowBox[{"sin", "(", 
       RowBox[{"m", " ", "\[Phi]"}], ")"}], " "}]}]}], TraditionalForm]], 
  "InlineMath"],
 ","
}], "ManipulateCaption",
 CellChangeTimes->{{3.5441374760524282`*^9, 3.544137593569433*^9}, {
  3.544137628781681*^9, 3.5441378537220507`*^9}, {3.5441378853012257`*^9, 
  3.5441379724733963`*^9}, {3.5441381323965673`*^9, 3.54413818119878*^9}, {
  3.544138214330649*^9, 3.544138248394665*^9}, {3.544138666424518*^9, 
  3.5441389301305857`*^9}, {3.544138986888008*^9, 3.544139002557199*^9}, {
  3.544139044813114*^9, 3.544139129305778*^9}, {3.544139178800358*^9, 
  3.544139197588026*^9}, {3.544139229980057*^9, 3.5441393111478167`*^9}, {
  3.544139353848302*^9, 3.5441393835182*^9}, {3.544139413871212*^9, 
  3.544139419779499*^9}, {3.5441394731764183`*^9, 3.544139473184369*^9}, {
  3.544139661577588*^9, 3.5441396705741253`*^9}, {3.544140356467063*^9, 
  3.544140356474601*^9}, {3.544464352867959*^9, 3.544464352922965*^9}, {
  3.544540766327261*^9, 3.544540774494528*^9}, {3.544541430609407*^9, 
  3.544541445330605*^9}},
 CellID->2073089276],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["x", "B"], "=", 
     RowBox[{
      RowBox[{"R", " ", "cos", " ", "\[Phi]"}], "+", 
      RowBox[{"b", " ", 
       RowBox[{"cos", "(", 
        RowBox[{"m", " ", "\[Phi]"}], ")"}]}]}]}], " ", ",", 
    RowBox[{
     SubscriptBox["y", "B"], "=", 
     RowBox[{
      RowBox[{"R", " ", "sin", " ", "\[Phi]"}], "+", 
      RowBox[{"b", " ", 
       RowBox[{"sin", "(", 
        RowBox[{"m", " ", "\[Phi]"}], ")"}], " "}]}]}]}], TraditionalForm]], 
  "InlineMath"],
 ","
}], "ManipulateCaption",
 CellChangeTimes->CompressedData["
1:eJxTTMoPSmViYGAQAWIQXbe28cHz9FeOZyyM3oPoDuaZn0E0l/R2/hdAesni
