Cell["\<\
It is not always so that theories which are equivalent are equally good, \
\>", "Text",
 CellChangeTimes->{{3.772170588379748*^9, 3.7721706023729725`*^9}},
 FontFamily->"Comic Sans MS",
 FontSize->11,
 CellTags->"Dirac",
 ExpressionUUID -> "83ce8b50-4ed9-45a7-a908-033bfa5bccbf"],

Cell["\<\
because one of them may be more suitable than the other for future \
development. \
\>", "Text",
 CellChangeTimes->{{3.772170588379748*^9, 3.772170603511774*^9}, {
  3.772170650436657*^9, 3.772170650436657*^9}},
 FontFamily->"Comic Sans MS",
 FontSize->11,
 ExpressionUUID -> "b46efbe2-d985-4e8e-9696-fc22e27a8150"],

Cell["\<\
                                                                   \[LongDash]\
\[LongDash] Paul Dirac \
\>", "Text",
