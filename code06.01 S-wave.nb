Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"yt", "[", 
    RowBox[{"x_", ",", "c2_"}], "]"}], ":=", 
   RowBox[{"Sin", "[", 
    RowBox[{"c2", "+", 
     RowBox[{"ArcSin", "[", "x", "]"}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"yplot", "[", 
    RowBox[{"x_", ",", "c2_"}], "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"c2", "<", "0"}], ",", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"x", "<", 
        RowBox[{"Sin", "[", 
         RowBox[{"c2", "-", 
          RowBox[{"\[Pi]", "/", "2"}]}], "]"}]}], ",", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "2"}], "-", 
         RowBox[{"yt", "[", 
          RowBox[{"x", ",", "c2"}], "]"}]}], ")"}], ",", 
       RowBox[{"yt", "[", 
        RowBox[{"x", ",", "c2"}], "]"}]}], "]"}], ",", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"x", ">", 
        RowBox[{"Sin", "[", 
         RowBox[{"c2", "+", 
          RowBox[{"\[Pi]", "/", "2"}]}], "]"}]}], ",", 
       RowBox[{"(", 
        RowBox[{"2", "-", 
         RowBox[{"yt", "[", 
          RowBox[{"x", ",", "c2"}], "]"}]}], ")"}], ",", 
       RowBox[{"yt", "[", 
        RowBox[{"x", ",", "c2"}], "]"}]}], "]"}]}], "]"}]}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"yt", "[", 
       RowBox[{"x", ",", "c2"}], "]"}], "/.", 
      RowBox[{"c2", "\[Rule]", "1.5"}]}], ",", 
     RowBox[{
      RowBox[{"yplot", "[", 
       RowBox[{"x", ",", "c2"}], "]"}], "/.", 
      RowBox[{"c2", "\[Rule]", "1.5"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}]}], "Input",
